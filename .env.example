# EaseSourcer backend config (copy to .env on each server and fill in real values)
# 真实密钥不要提交到仓库；这里只放占位示例。

# HTTP port the app listens on (behind nginx/Cloudflare tunnel)
PORT=4100

# Shared fixed password for app-level login (see PRD: lightweight auth, no user system)
APP_PASSWORD=change-me

# Session cookie signing secret (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# AIGW relay (the Python relay on the Mac Mini, reached over the reverse tunnel)
AIGW_RELAY_URL=http://127.0.0.1:4500
AIGW_RELAY_TOKEN=your-relay-token

# Model ids (AIGW传参模型代号)
TEXT_MODEL=claude-opus-4-6
IMAGE_MODEL=gemini-3-pro-image

# Filesystem data root for projects + assets
DATA_DIR=./data

# External integration API keys accepted by /api/ext/* (comma-separated)
EXT_API_KEYS=esk_test_xxxxxxxx,esk_live_xxxxxxxx

# Optional IP allowlist for /api/ext/* (comma-separated; empty = disabled)
EXT_IP_ALLOWLIST=

# Public base URL for externally-reachable asset links in exported JSON
PUBLIC_BASE_URL=https://your-domain.example.com

# Fixed site-wide contact written into every landing page
SITE_WHATSAPP=+0000000000
SITE_EMAIL=sales@example.com
